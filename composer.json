{
    "name": "alecscodes/inertia-i18n",
    "description": "Minimal i18n for Laravel Inertia — share PHP and JSON translations with t() and tc() on the frontend",
    "support": {
        "issues": "https://github.com/alecscodes/inertia-i18n/issues",
        "source": "https://github.com/alecscodes/inertia-i18n"
    },
    "keywords": [
        "laravel",
        "inertia",
        "i18n",
        "translations",
        "localization"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexx",
            "email": "kestrel-05-spate@icloud.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "inertiajs/inertia-laravel": "^2.0 || ^3.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/view": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "AlecsCodes\\InertiaI18n\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlecsCodes\\InertiaI18n\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlecsCodes\\InertiaI18n\\InertiaI18nServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
